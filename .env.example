# Base de datos
DATABASE_URL=postgresql://postgres:password@localhost:5432/maquinaria_dev

# JWT
JWT_SECRET=change_this_secret_in_production
JWT_EXPIRES_IN=7d

# API
API_PORT=3000
API_HOST=localhost
NODE_ENV=development

# Storage (preparado para S3)
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./uploads
